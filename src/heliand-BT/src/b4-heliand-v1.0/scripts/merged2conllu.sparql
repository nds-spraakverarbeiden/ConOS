# update local IDs
DELETE {
	?w conll:ID ?id
} INSERT {
	?w conll:ID ?newid
} WHERE {
	?w a nif:Word.
	{ SELECT ?w (COUNT(distinct ?pre) as ?pos)
	  WHERE {
		?w a nif:Word.
		?pre nif:nextWord* ?w
	  } GROUP BY ?w
	}
	OPTIONAL {
		?w conll:ID ?id.
	}
	BIND(str(?pos) as ?newid)
};

# generate NEW_HEAD
INSERT {
	?w conll:NEW_HEAD ?hid
} WHERE {
	{	?w conll:HEAD/conll:ID ?hid } UNION
	{	?w conll:HEAD/a nif:Sentence. BIND("0" as ?hid) }
};