#####################
# postproces syntax #
#####################

# move punct to: head of spanning dependency > preceding root > following root
DELETE {
	?p conll:HEAD ?h
} INSERT {
	?p conll:HEAD ?a
} WHERE {
	?p conll:EDGE "punct".
	?p conll:HEAD ?h.
	{ # attach to head of spanning dependency
	  ?a nif:nextWord+ ?p. 
	  ?p nif:nextWord+/conll:HEAD ?a 
	} UNION {
	  # attach to head of spanning dependency
	  ?p nif:nextWord+ ?a.
	  [conll:HEAD ?a] nif:nextWord+ ?p
	} UNION {
		# no spanning dependency => attach to preceding Root
		?a conll:HEAD/a nif:Sentence.
		?a nif:nextWord+ ?p.
		MINUS {
			?pre nif:nextWord+ ?p; (conll:HEAD|^conll:HEAD) ?post.
			?p nif:nextWord+ ?post
		}
		MINUS {	# ?a is the latest root
			?a nif:nextWord+ [ conll:HEAD/a nif:Sentence; nif:nextWord+ ?p ]
		}
	} UNION {
		# no spanning dependency and no preceding Root => attach to following Root
		?a conll:HEAD/a nif:Sentence.
		?p nif:nextWord+ ?a.
		MINUS {	# no spanning dependency
			?pre nif:nextWord+ ?p; (conll:HEAD|^conll:HEAD) ?post.
			?p nif:nextWord+ ?post
		}
		MINUS { # no preceding root
			[ conll:HEAD/a nif:Sentence ] nif:nextWord+ ?p
		}
		MINUS { # next preceding root
			?p nif:nextWord+ [ conll:HEAD/a nif:Sentence; nif:nextWord+ ?a ]
		}
	}
};

