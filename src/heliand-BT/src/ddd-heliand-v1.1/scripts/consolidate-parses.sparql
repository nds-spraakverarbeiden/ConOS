###############
# create XPOS #
###############

# restore HPOS from DHPOS (HPOS extrapolated from DPOS)
DELETE {
	?a conll:MISC ?misc.
} INSERT {
	?a conll:HPOS ?dhpos; conll:MISC ?new_misc.
} WHERE {
	?a conll:DHPOS ?dhpos.
	MINUS { ?a conll:HPOS [] }
	BIND("DHPOS>HPOS" as ?comment)
	OPTIONAL {
		?a conll:MISC ?misc
	}
	BIND(if(bound(?misc), concat(?misc,";",?comment), ?comment) as ?new_misc)	
};

# set XPOS to HPOS|DPOS.DFEATS
INSERT {
	?a conll:XPOS ?xpos
} WHERE {
	?a a nif:Word.
	OPTIONAL { ?a conll:DPOS ?dpos }	# may be missing for multi-token annotations
	OPTIONAL { ?a conll:HPOS ?hpos }
	OPTIONAL { ?a conll:DFEATS ?dfeats }
	BIND(
		replace(
			concat(
				if(bound(?hpos), ?hpos,"_"),
				"|",
				if(bound(?dpos), ?dpos,"_"),
				if(bound(?dfeats), concat(".",?dfeats), "") 
			),
			"\\s", "")
			as ?xpos )
};

##################
# postprocessing #
##################

# pruning: remove DEDGE, DHEAD, HHEAD, HEDGE, HLEMMA, HPOS, DHPOS, DPOS, DFEATS
DELETE {
	?a ?prop ?b
} WHERE {
	?a a nif:Word; ?prop ?b.
	FILTER(?prop in (conll:DEDGE,conll:DHEAD,conll:HHEAD,conll:HEDGE, conll:HLEMMA, conll:HPOS, conll:DHPOS, conll:DPOS, conll:DFEATS))
};

# fix multi-head assignment: resort to the last head  # TODO: debug properly
DELETE {
	?a conll:HEAD ?h1; conll:MISC ?misc.
} INSERT {
	?a conll:MISC ?new_misc
} WHERE {
	?a conll:HEAD ?h1, ?h2.
	?h1 nif:nextWord+ ?h2.
	BIND("dedup_head" as ?comment)
	OPTIONAL {
		?a conll:MISC ?misc
	}
	BIND(if(bound(?misc), concat(?misc,";",?comment), ?comment) as ?new_misc)	
};

# cast ID to integers to enforce the order
DELETE {
	?w conll:ID ?id
} INSERT {
	?w conll:ID ?newid
} WHERE {
	?w conll:ID ?id
	BIND(xsd:int(?id) as ?newid)
};

# # merge comments
# DELETE {
	# ?a conll:MISC ?misc
# } INSERT {
	# ?a conll:MISC ?new_misc
# } WHERE {
	# { SELECT ?a (group_concat(distinct ?m; separator="|") as ?new_misc)
	  # WHERE {
		# ?a conll:MISC ?m
	 # } GROUP BY ?a ORDER BY ?a ?m
	# }
	# ?a conll:MISC ?misc
# };

# the following is SLOW: drop if unneccessary

# drop empty lines, restore order from IDs
DELETE {
	?a ?b ?empty.
	?empty ?c ?d.
} WHERE {
	?empty conll:XPOS []
	MINUS {
		?empty conll:WORD []
	}
	?a ?b ?empty.
	?empty ?c ?d.
};

# drop and restore nif:nextWord from IDs
DELETE {
	?a nif:nextWord ?b
} WHERE {
	?a nif:nextWord ?b.
	?a conll:HEAD+ ?s.
	?s a nif:Sentence.
	?b conll:HEAD+ ?s.
};

INSERT {
	?a nif:nextWord ?b
} WHERE {
	?s a nif:Sentence.
	?a conll:HEAD+ ?s; conll:ID ?aid.
	?b conll:HEAD+ ?s; conll:ID ?bid.
	FILTER(?a != ?b)
	FILTER(xsd:int(?aid)<xsd:int(?bid))
	MINUS {
		?s a nif:Sentence.
		?a conll:HEAD+ ?s; conll:ID ?aid.
		?b conll:HEAD+ ?s; conll:ID ?bid.
		?c conll:HEAD+ ?s; conll:ID ?cid.
		FILTER(?a != ?b)
		FILTER(?a != ?c)
		FILTER(?b != ?c)
		FILTER(xsd:int(?aid)<xsd:int(?cid))
		FILTER(xsd:int(?cid)<xsd:int(?bid))
	}
};
