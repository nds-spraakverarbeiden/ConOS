# restructure CLAUSE annotations to powla nodes (a conll:CLAUSE with property conll:CAT)

# consolidate DDD annotations
# create PTB-style syntax in PARSE
# - split MWEs and keep as phrase
# - create clause nodes
# - split ROLE(S) from CAT labels
# - connect opening and closing clauses
# - create sentence nodes
# consolidate CHAP and VERSE into VERSE

PREFIX nif: <http://persistence.uni-leipzig.org/nlp2rdf/ontologies/nif-core#>
PREFIX conll: <http://ufal.mff.cuni.cz/conll2009-st/task-description.html#>
PREFIX x: <http://purl.org/acoli/conll-rdf/xml#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX terms: <http://purl.org/acoli/open-ie/>
PREFIX powla: <http://purl.org/powla/powla.owl#>

# remove IGNORE
DELETE {
	?a conll:IGNORE ?i
} WHERE {
	?a conll:IGNORE ?i
};

# remove empty annotations (marked here *)
DELETE {
	?a ?b "*"
} WHERE {
	?a ?b "*"
};

# split multi-word expressions
# can contain up to 5 tokens
DELETE {
	?last nif:nextWord ?w.
	?w nif:nextWord ?next.
	?w a nif:Word; conll:WORD ?word.
	?a ?b ?w.
	?w ?c ?d.
} INSERT {
	?last nif:nextWord ?w1.
	?w1 nif:nextWord ?w2; a nif:Word; conll:WORD ?pre; powla:hasParent ?w.
	?w2 nif:nextWord ?next; a nif:Word; conll:WORD ?post; powla:hasParent ?w.
	?w a powla:Node, conll:MWE; conll:CAT ?pos.
	?a ?b ?w1. ?a ?b ?w2.
	?w1 ?c ?d. ?w2 ?c ?d.
} WHERE {
	?w a nif:Word; conll:WORD ?word; conll:POS ?pos.
	FILTER(contains(?word,' '))
	BIND(replace(?word,' .*','') AS ?pre)
	BIND(replace(?word,'^[^ ]* +','') AS ?post)
	BIND(URI(concat(str(?w),'_1')) AS ?w1)
	BIND(URI(concat(str(?w),'_2')) AS ?w2)	
	OPTIONAL { ?a ?b ?w.
		FILTER(strstarts(str(?b), 'http://ufal.mff.cuni.cz/conll2009-st/task-description.html#'))
	}
	OPTIONAL { ?w ?c ?d.
		FILTER(isLiteral(?d) || strstarts(str(?c), 'http://ufal.mff.cuni.cz/conll2009-st/task-description.html#'))
		FILTER(?c!=conll:WORD)
	}
	OPTIONAL { ?last nif:nextWord ?w. }
	OPTIONAL { ?w nif:nextWord ?next. }
};

# split tokens: 1st iteration
DELETE {
	?last nif:nextWord ?w.
	?w nif:nextWord ?next.
	?w a nif:Word; conll:WORD ?word.
	?a ?b ?w.
	?w ?c ?d.
} INSERT {
	?last nif:nextWord ?w1.
	?w1 nif:nextWord ?w2; a nif:Word; conll:WORD ?pre; powla:hasParent ?W.
	?w2 nif:nextWord ?next; a nif:Word; conll:WORD ?post; powla:hasParent ?W.
	?w a powla:Node, conll:MWE; conll:CAT ?pos.
	?a ?b ?w1. ?a ?b ?w2.
	?w1 ?c ?d. ?w2 ?c ?d.
} WHERE {
	?w a nif:Word; conll:WORD ?word; conll:POS ?pos.
	FILTER(contains(?word,' '))
	?w powla:hasParent* ?W.
	MINUS { ?W powla:hasParent [] }
	BIND(replace(?word,' .*','') AS ?pre)
	BIND(replace(?word,'^[^ ]* +','') AS ?post)
	BIND(URI(concat(str(?w),'_1')) AS ?w1)
	BIND(URI(concat(str(?w),'_2')) AS ?w2)	
	OPTIONAL { ?a ?b ?w.
		FILTER(strstarts(str(?b), 'http://ufal.mff.cuni.cz/conll2009-st/task-description.html#'))
	}
	OPTIONAL { ?w ?c ?d.
		FILTER(isLiteral(?d) || strstarts(str(?c), 'http://ufal.mff.cuni.cz/conll2009-st/task-description.html#'))
		FILTER(?c!=conll:WORD)
	}
	OPTIONAL { ?last nif:nextWord ?w. }
	OPTIONAL { ?w nif:nextWord ?next. }
};

# split tokens: 2nd iteration
DELETE {
	?last nif:nextWord ?w.
	?w nif:nextWord ?next.
	?w a nif:Word; conll:WORD ?word.
	?a ?b ?w.
	?w ?c ?d.
} INSERT {
	?last nif:nextWord ?w1.
	?w1 nif:nextWord ?w2; a nif:Word; conll:WORD ?pre; powla:hasParent ?W.
	?w2 nif:nextWord ?next; a nif:Word; conll:WORD ?post; powla:hasParent ?W.
	?w a powla:Node, conll:MWE; conll:CAT ?pos.
	?a ?b ?w1. ?a ?b ?w2.
	?w1 ?c ?d. ?w2 ?c ?d.
} WHERE {
	?w a nif:Word; conll:WORD ?word; conll:POS ?pos.
	FILTER(contains(?word,' '))
	?w powla:hasParent* ?W.
	MINUS { ?W powla:hasParent [] }
	BIND(replace(?word,' .*','') AS ?pre)
	BIND(replace(?word,'^[^ ]* +','') AS ?post)
	BIND(URI(concat(str(?w),'_1')) AS ?w1)
	BIND(URI(concat(str(?w),'_2')) AS ?w2)	
	OPTIONAL { ?a ?b ?w.
		FILTER(strstarts(str(?b), 'http://ufal.mff.cuni.cz/conll2009-st/task-description.html#'))
	}
	OPTIONAL { ?w ?c ?d.
		FILTER(isLiteral(?d) || strstarts(str(?c), 'http://ufal.mff.cuni.cz/conll2009-st/task-description.html#'))
		FILTER(?c!=conll:WORD)
	}
	OPTIONAL { ?last nif:nextWord ?w. }
	OPTIONAL { ?w nif:nextWord ?next. }
};

# split tokens: 3rd iteration
DELETE {
	?last nif:nextWord ?w.
	?w nif:nextWord ?next.
	?w a nif:Word; conll:WORD ?word.
	?a ?b ?w.
	?w ?c ?d.
} INSERT {
	?last nif:nextWord ?w1.
	?w1 nif:nextWord ?w2; a nif:Word; conll:WORD ?pre; powla:hasParent ?W.
	?w2 nif:nextWord ?next; a nif:Word; conll:WORD ?post; powla:hasParent ?W.
	?w a powla:Node, conll:MWE; conll:CAT ?pos.
	?a ?b ?w1. ?a ?b ?w2.
	?w1 ?c ?d. ?w2 ?c ?d.
} WHERE {
	?w a nif:Word; conll:WORD ?word; conll:POS ?pos.
	FILTER(contains(?word,' '))
	?w powla:hasParent* ?W.
	MINUS { ?W powla:hasParent [] }
	BIND(replace(?word,' .*','') AS ?pre)
	BIND(replace(?word,'^[^ ]* +','') AS ?post)
	BIND(URI(concat(str(?w),'_1')) AS ?w1)
	BIND(URI(concat(str(?w),'_2')) AS ?w2)	
	OPTIONAL { ?a ?b ?w.
		FILTER(strstarts(str(?b), 'http://ufal.mff.cuni.cz/conll2009-st/task-description.html#'))
	}
	OPTIONAL { ?w ?c ?d.
		FILTER(isLiteral(?d) || strstarts(str(?c), 'http://ufal.mff.cuni.cz/conll2009-st/task-description.html#'))
		FILTER(?c!=conll:WORD)
	}
	OPTIONAL { ?last nif:nextWord ?w. }
	OPTIONAL { ?w nif:nextWord ?next. }
};

# split tokens: 4th iteration
DELETE {
	?last nif:nextWord ?w.
	?w nif:nextWord ?next.
	?w a nif:Word; conll:WORD ?word.
	?a ?b ?w.
	?w ?c ?d.
} INSERT {
	?last nif:nextWord ?w1.
	?w1 nif:nextWord ?w2; a nif:Word; conll:WORD ?pre; powla:hasParent ?W.
	?w2 nif:nextWord ?next; a nif:Word; conll:WORD ?post; powla:hasParent ?W.
	?w a powla:Node, conll:MWE; conll:CAT ?pos.
	?a ?b ?w1. ?a ?b ?w2.
	?w1 ?c ?d. ?w2 ?c ?d.
} WHERE {
	?w a nif:Word; conll:WORD ?word; conll:POS ?pos.
	FILTER(contains(?word,' '))
	?w powla:hasParent* ?W.
	MINUS { ?W powla:hasParent [] }
	BIND(replace(?word,' .*','') AS ?pre)
	BIND(replace(?word,'^[^ ]* +','') AS ?post)
	BIND(URI(concat(str(?w),'_1')) AS ?w1)
	BIND(URI(concat(str(?w),'_2')) AS ?w2)	
	OPTIONAL { ?a ?b ?w.
		FILTER(strstarts(str(?b), 'http://ufal.mff.cuni.cz/conll2009-st/task-description.html#'))
	}
	OPTIONAL { ?w ?c ?d.
		FILTER(isLiteral(?d) || strstarts(str(?c), 'http://ufal.mff.cuni.cz/conll2009-st/task-description.html#'))
		FILTER(?c!=conll:WORD)
	}
	OPTIONAL { ?last nif:nextWord ?w. }
	OPTIONAL { ?w nif:nextWord ?next. }
};

# split tokens: 5th iteration
DELETE {
	?last nif:nextWord ?w.
	?w nif:nextWord ?next.
	?w a nif:Word; conll:WORD ?word.
	?a ?b ?w.
	?w ?c ?d.
} INSERT {
	?last nif:nextWord ?w1.
	?w1 nif:nextWord ?w2; a nif:Word; conll:WORD ?pre; powla:hasParent ?W.
	?w2 nif:nextWord ?next; a nif:Word; conll:WORD ?post; powla:hasParent ?W.
	?w a powla:Node, conll:MWE; conll:CAT ?pos.
	?a ?b ?w1. ?a ?b ?w2.
	?w1 ?c ?d. ?w2 ?c ?d.
} WHERE {
	?w a nif:Word; conll:WORD ?word; conll:POS ?pos.
	FILTER(contains(?word,' '))
	?w powla:hasParent* ?W.
	MINUS { ?W powla:hasParent [] }
	BIND(replace(?word,' .*','') AS ?pre)
	BIND(replace(?word,'^[^ ]* +','') AS ?post)
