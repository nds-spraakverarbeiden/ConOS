# require HeliPaD annotations as follows:
# - powla:Node with basic syntactic tags in conll:CAT, optionally extended syntactic tags in conll:ROLE (multiple, trailing - stripped)
# - nif:Word with conll:POS, optionally conll:FEAT

# known issues: 
# - copular treated as aux rather than cop

PREFIX nif: <http://persistence.uni-leipzig.org/nlp2rdf/ontologies/nif-core#>
PREFIX conll: <http://ufal.mff.cuni.cz/conll2009-st/task-description.html#>
PREFIX x: <http://purl.org/acoli/conll-rdf/xml#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX terms: <http://purl.org/acoli/open-ie/>
PREFIX powla: <http://purl.org/powla/powla.owl#>

########################
# simplify annotations #
########################

# typos
INSERT { ?node conll:CAT "ADJP" } WHERE { ?node conll:CAT "ADJ" };
INSERT { ?node conll:POS "PRO$" } WHERE { ?node conll:POS "PRO$" };
INSERT { ?node conll:POS "WADV" } WHERE { ?node conll:POS "WADVP" };

# ms. errors
# treat X like CPX or IPX (i.e., if verbal, set verb to head)
INSERT {
	?node conll:CAT "CPX","IPX"
} WHERE {
	?node conll:CAT "X"
};

# WNP => NP, etc. (keep both)
INSERT {
	?node conll:CAT ?plain
} WHERE {
	?node conll:CAT ?w
	FILTER(strstarts(?w,'W'))
	BIND(replace(?w,"^W","") AS ?plain)
};

# QTP => NP, etc. (keep both)
INSERT {
	?node conll:CAT "NP"
} WHERE {
	?node conll:CAT "QTP"
};

# IPX, CPX => IP, CP (keep both)
INSERT {
	?node conll:CAT ?plain
} WHERE {
	?node conll:CAT ?cat
	FILTER(strends(?cat,'X'))
	BIND(replace(?cat,'X$','') AS ?plain)
	FILTER(?plain in ('IP','CP'))
};

# WADV => ADV, etc. (keep both)
INSERT {
	?node conll:POS ?plain
} WHERE {
	?node conll:POS ?w
	FILTER(strstarts(?w,'W'))
	BIND(replace(?w,"^W","") AS ?plain)
};

# ADJR, etc. => ADJ (keep both)
INSERT {
	?node conll:POS ?positive
} WHERE {
	?node conll:POS ?comparative.
	FILTER(strends(?comparative,'R'))
	BIND(replace(?comparative,'R$','') AS ?positive)
	FILTER(?positive in ('ADJ','ADV', 'Q'))
};

# ADJS, etc. => ADJ (keep both)
INSERT {
	?node conll:POS ?positive
} WHERE {
	?node conll:POS ?superlative.
	FILTER(strends(?superlative,'S'))
	BIND(replace(?superlative,'S$','') AS ?positive)
	FILTER(?positive in ('ADJ','ADV','Q'))
};

# VGI, VNI, VBI, PRO$ => ADJ (keep both)
INSERT {
	?node conll:POS "ADJ"
} WHERE {
	?node conll:POS ?pos.
	FILTER(?pos in ('VGI','VNI','PRO$'))
};

# NUMP => ADJP (keep both)
INSERT {
	?node conll:POS "ADJP"
} WHERE {
	?node conll:POS "NUMP".
};

# remove CODE from parse (note that we keep it in the powla:next sequence)
DELETE {
	?code powla:hasParent ?node
} WHERE {
	?code conll:POS "CODE"; powla:hasParent ?node
};

# remove punctuation from parse
DELETE {
	?punct powla:hasParent ?node
} WHERE {
	?punct conll:POS ?pos; powla:hasParent ?node
	FILTER(?pos in ('"',"'", ',', '.'))
};

######################
# set syntactic head #
######################

# define syntactic HEAD within every phrase, using terms:HEAD
# (a) non-branching phrases
INSERT {
	?node terms:HEAD ?head; rdfs:comment "(a)".
} WHERE {
	?node a conll:PARSE.
	?head powla:hasParent ?node.
	MINUS { ?head powla:hasParent/^powla:hasParent ?tmp FILTER(?tmp!=?head)}
};

# (b) HEAD of CONJP is the first conjunct, CONJP inherits its CAT
INSERT {
	?node terms:HEAD ?head; conll:CAT ?cat; rdfs:comment "(b)"
} WHERE {
	?node conll:CAT "CONJP".
	MINUS { ?node terms:HEAD [] }
	?head a conll:PARSE; powla:hasParent ?node.
	MINUS { [ a conll:PARSE; powla:hasParent ?node] powla:next+ ?head }
	?head conll:CAT ?cat.
};

# (c.1) HEAD of PP is NP (not the preposition)
INSERT {
	?node terms:HEAD ?head; rdfs:comment "(c.1)"
} WHERE {
	?node conll:CAT "PP".
	MINUS { ?node terms:HEAD [] }
	?head powla:hasParent ?node.
	?head conll:CAT "NP"
};

# (c.2) HEAD of PP is first non-P
INSERT {
	?node terms:HEAD ?head; rdfs:comment "(c.2)"
} WHERE {
	?node conll:CAT "PP".
	MINUS { ?node terms:HEAD [] }
	?head powla:hasParent ?node.
	MINUS { ?head conll:POS "P" }
	MINUS {
		?head powla:hasParent ?node.
		MINUS { ?head conll:POS "P" }
		?head powla:next+ ?tmp.
		?tmp powla:hasParent ?node.
		MINUS { ?tmp conll:POS "P" }
	}		
};

# (d.1) HEAD of NP or PP is last nominal (N or NPR)
INSERT {
	?node terms:HEAD ?head; rdfs:comment "(d.1)"
} WHERE {
	?node conll:CAT ?np.
	FILTER(?np in ("NP","PP"))
	MINUS { ?node terms:HEAD [] }
	?head powla:hasParent ?node; conll:POS ?nominal.
	FILTER(?nominal in ("N","NPR"))
	MINUS { ?head powla:next+/conll:POS "N" }
	MINUS { ?head powla:next+/conll:POS "NPR" }
};

# (d.2) HEAD of headless NP can also be (last) QP,Q,ADJP,ADJ,NUM or PRO
INSERT {
	?node terms:HEAD ?head; rdfs:comment "(d.2)"
} WHERE {
	?node conll:CAT "NP".
	MINUS { ?node terms:HEAD [] }
	?head powla:hasParent ?node; (conll:POS|conll:CAT) ?nominal.
	FILTER(?nominal in ("QP","Q","ADJP","ADJ","PRO","NUM"))
	MINUS { ?head powla:nextWord+/(conll:POS|conll:CAT) "QP" }
	MINUS { ?head powla:nextWord+/(conll:POS|conll:CAT) "Q" }
	MINUS { ?head powla:nextWord+/(conll:POS|conll:CAT) "NUM" }
	MINUS { ?head powla:nextWord+/(conll:POS|conll:CAT) "ADJP" }
	MINUS { ?head powla:nextWord+/(conll:POS|conll:CAT) "ADJ" }
	MINUS { ?head powla:nextWord+/(conll:POS|conll:CAT) "PRO" }
};

# (d.3) HEAD of headless NP can also be a that-clause (THT) or a relative clause (REL)
INSERT {
	?node terms:HEAD ?head; rdfs:comment "(d.3)"
} WHERE {
	?node conll:CAT ?cat. FILTER(?cat in ("NP",'PP'))
	MINUS { ?node terms:HEAD [] }
	?head powla:hasParent ?node; conll:ROLE ?role.
	FILTER(?role in ("THT","REL"))
};

# (d.4) HEAD of headless NP can be the first non-determiner
INSERT {
	?node terms:HEAD ?head; rdfs:comment "(d.4)"
} WHERE {
	?node conll:CAT "NP".
	MINUS { ?node terms:HEAD [] }
	?head powla:hasParent ?node.
	MINUS { ?head conll:POS ?pos. FILTER(?pos='D') }
	MINUS { 
			?head powla:hasParent ?node; conll:POS ?pos.
			MINUS { ?head conll:POS ?pos. FILTER(?pos='D') }
			?tmp powla:next+ ?head.
			?tmp powla:hasParent ?node; conll:POS ?tmpPos.
			MINUS { ?tmp conll:POS ?pos. FILTER(?pos='D') }
		}
};

# (e) HEAD of ADJP, ADVP, NUMP or QP is the last ADJ, ADV, etc.
INSERT {
	?node terms:HEAD ?head; rdfs:comment "(e)"
} WHERE {
	?node conll:CAT ?cat.
	MINUS { ?node terms:HEAD [] }
	FILTER(?cat in ("ADJP","ADVP","NUMP","QP", "INTJP"))
	BIND(replace(?cat,'P$','') AS ?pos)
	?head conll:POS ?pos; powla:hasParent ?node.
	MINUS { ?head powla:next+ [ conll:POS ?pos ]}
};
	
# (f) first main clause is head of anything 
INSERT {
	?node terms:HEAD ?head; rdfs:comment "(f)"
} WHERE {
	?head conll:CAT "IP"; conll:ROLE "MAT".
	?head powla:hasParent ?node.
	MINUS { ?node terms:HEAD [] }
	MINUS { [conll:CAT "IP"; conll:ROLE "MAT"] powla:next+ ?head }
};

# (g) HEAD of CP is first IP
INSERT {
	?node terms:HEAD ?head; rdfs:comment "(g)"
} WHERE {
	?node conll:CAT "CP".
	MINUS { ?node terms:HEAD [] }
	?head powla:hasParent ?node; conll:CAT "IP".
	MINUS { [conll:CAT "IP" ] powla:next+ ?head }
};
	
# (h.1) HEAD of IP/PTP is (first) verb
INSERT {
	?node terms:HEAD ?head; rdfs:comment "(h.1)"
} WHERE {
	?node conll:CAT ?cat FILTER(?cat in ('IP','PTP')).
	MINUS { ?node terms:HEAD [] }
	?head powla:hasParent ?node; conll:POS ?pos.
	FILTER(strstarts(?pos,'V'))
};

# (h.2) HEAD of verbless IP is (first) predicate
INSERT {
	?node terms:HEAD ?head; rdfs:comment "(h.2)"
} WHERE {
	?node conll:CAT ?cat FILTER(?cat in ('IP','PTP')).
	MINUS { ?node terms:HEAD [] }
	?head powla:hasParent ?node; conll:ROLE "PRD".
};

# (h.3) HEAD of headless IP can be (last) auxiliary
INSERT {
	?node terms:HEAD ?head; rdfs:comment "(h.3)"
} WHERE {
	?node conll:CAT ?cat FILTER(?cat in ('IP','PTP')).
	MINUS { ?node terms:HEAD [] }
	?head powla:hasParent ?node; conll:POS ?pos
	FILTER(regex(?pos,'^(BE|M[DG]|H|R[DGN]).*'))
	MINUS {
		?head powla:next+/conll:POS ?tmp.
		FILTER(regex(?tmp,'^(BE|MD|H|R[DGN]).*'))
	}
};

# (h.4) HEAD of IP-SMC can be the first non-subject argument
INSERT {
	?node terms:HEAD ?head; rdfs:comment "(h.4)"
} WHERE {
	?node conll:CAT ?cat FILTER(?cat in ('IP','PTP')).
	?node conll:ROLE "SMC".
	MINUS { ?node terms:HEAD [] }
	?head powla:hasParent ?node.
	MINUS { ?head conll:ROLE "SBJ" }
	MINUS { ?head powla:hasParent ?node.
			MINUS { ?head conll:ROLE "SBJ" }
			?tmp powla:next+ ?head
			MINUS { ?tmp conll:ROLE "SBJ" }
		}
};

# (h.5) HEAD of headless IPX can be the subject
INSERT {
	?node terms:HEAD ?head; rdfs:comment "(h.5)"
} WHERE {
	?node conll:CAT "IPX".
	MINUS { ?node terms:HEAD [] }
	?head powla:hasParent ?node; conll:ROLE "SBJ".
};

# (i) phrases can be recursive, i.e., if it doesn't have a head but contains a phrase of the same type, then this phrase may be the same
# e.g. (PP(PP mid uuordun) (CONJP endi (PP mid uuercun))) 
# set to the first candidate
INSERT {
	?node terms:HEAD ?head; rdfs:comment "(i)"
} WHERE {
	?node conll:CAT ?cat.
	MINUS { ?node terms:HEAD [] }
	?head powla:hasParent ?node; conll:CAT ?cat.
	MINUS { [conll:CAT ?cat ] powla:next+ ?head }
};

# (j) head of headless CP can be the (first) verb
INSERT {
	?cp terms:HEAD ?head; rdfs:comment "(j)"
} WHERE {
	?cp conll:CAT "CP".
	MINUS { ?cp terms:HEAD [] }
	?head powla:hasParent ?cp; conll:POS ?pos
	FILTER(strstarts(?pos,'V') || ?pos in ('VBDI','VBPI')) # explicitly these pos, for uncaptured errors in sentence 979 and 2099
};

# (k) head of IPX, CPX is the first non-empty element, i.e., one those children contain a POS
INSERT {
	?fragment terms:HEAD ?head; rdfs:comment "(k)"
} WHERE {
	?fragment conll:CAT ?cat.
	FILTER(?cat in ('IPX','CPX'))
	MINUS { ?fragment terms:HEAD [] }
	?head powla:hasParent ?fragment; (^powla:hasParent)*/conll:POS []. # must not be empty
	MINUS { 
		?tmp powla:next+ ?head; (^powla:hasParent)*/conll:POS []; powla:hasParent ?fragment.	# must be first
	}
};

# (l) head of LATIN is the first content word
INSERT {
	?latin terms:HEAD ?head; rdfs:comment "(l)"
} WHERE {
	?latin conll:CAT "LATIN".
	MINUS { ?latin terms:HEAD [] }
	?head powla:hasParent ?latin; (^powla:hasParent)*/conll:POS [].
	MINUS {
		?tmp powla:next+ ?head; powla:hasParent ?latin; (^powla:hasParent)*/conll:POS []
	}
};

# (m.1) head of X that cannot be recovered as CPX or IPX is the (first) comment (explaining the reason of ungrammaticality)
# (not used)
INSERT {
	?x terms:HEAD ?comment; rdfs:comment "(m.1)"
} WHERE {
	?x conll:CAT "X".
	MINUS { ?x terms:HEAD [] }
	?comment powla:hasParent ?x; conll:POS "CODE"; conll:WORD ?w.
	FILTER(strstarts(?w, "<COM:"))
};

# (m.2) head of "unrepaired" X is first non-empty child
# (not used)
INSERT {
	?x terms:HEAD ?head; rdfs:comment "(m.2)"
} WHERE {
	?x conll:CAT "X".
	MINUS { ?x terms:HEAD [] }
	?head powla:hasParent ?x; (^powla:hasParent)*/conll:POS [].
	MINUS { ?tmp powla:hasParent ?x; powla:next+ ?head; (^powla:hasParent)*/conll:POS [] }
};

################
# repair rules #
################

# repair rules for headless phrases based on the "headiness" of their children: verb > noun > other content words (incl. finite aux) > phrases > adv > function words
# (if used, this is marked with an rdfs:comment)
# occurs with QTP phrases ("non-clausal direct speech") as these have no pre-defined internal organization

# finite verb > infinite verb > imperative aux > noun
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "VBI" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "VBPI" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "VBPS" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "VBDI" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "VBDS" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "VB" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "VGI" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "VNI" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "VBG" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "VG" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "VN" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "HVI" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "MDI" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "RDI" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "BEI" };

# name > noun > pronoun > adjective > aux
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "NPR" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "N" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "PRO" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "WPRO" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "ADJ" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "WADJ" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "ADJR" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "ADJS" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "POS" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "PRO$" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "PROS" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "NUM" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "Q" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "QR" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "QS" };	

# finite aux > phrases 
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "BEPI" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "HVPI" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "MDPI" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "RDPI" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "BEPS" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "HVPS" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "MDPS" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "RDPS" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "BEDI" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "HVDI" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "MDDI" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "RDDI" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "BEDS" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "HVDS" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "MDDS" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:POS "RDDS" };

# phrases (IP > NP > PP > CP > other) > adv
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:CAT "IP" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:CAT "IPX" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:CAT "WNP" };
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] }. ?y conll:CAT "NP" };
