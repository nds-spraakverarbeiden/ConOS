# absolute fallback: first element
INSERT { ?x terms:HEAD ?y; rdfs:comment "warning: no applicable HEAD rule found, using default"  } WHERE { ?y powla:hasParent ?x. MINUS { ?x terms:HEAD [] } };

# repair: multiple heads: keep the first # shouldn't happen with carefully designed rules, but this fallback allows us to be sloppy above when we want the first suitable element to be head
DELETE {
	?node terms:HEAD ?second; rdfs:comment ?comment
} WHERE {
	?node terms:HEAD ?first, ?second.
	?first powla:next+ ?second.
	BIND(concat("remove terms:HEAD "+str(?second)) as ?comment)
};

#######################
# create dependencies #
#######################

# create HEAD and EDGE properties top-down
DELETE {
	?w conll:HEAD ?s
} INSERT {
	?w conll:HEAD ?head; conll:EDGE ?role, ?cat, ?nodePair.
} WHERE {
	?head a nif:Word; (^terms:HEAD)+ ?phrase.
	?dependant powla:hasParent ?phrase. 
	MINUS { ?phrase terms:HEAD ?dependant }
	OPTIONAL { ?dependant conll:ROLE ?role. }
	OPTIONAL { ?dependant conll:CAT ?cat; powla:hasParent ?phrase. ?phrase conll:CAT ?phraseCat. BIND(concat(?cat,'-',?phraseCat) AS ?nodePair) }
	OPTIONAL { ?dependant conll:POS ?pos; powla:hasParent ?phrase. ?phrase conll:CAT ?phraseCat. BIND(concat(?pos,'-',?phraseCat) AS ?nodePair) }

	?dependant terms:HEAD* ?w.
	?w a nif:Word; conll:HEAD ?s.
	?s a nif:Sentence.
};

# attach non-tokens to head of any relation that spans over it
DELETE {
	?w conll:HEAD ?s.
} INSERT {
	?w conll:HEAD ?y.
} WHERE {
	?w conll:HEAD ?s.
	?s a nif:Sentence.
	?w conll:POS ?pos
	FILTER(regex(?pos,'^[^A-Z]$|CODE'))
	{ ?x nif:nextWord+ ?w. ?x conll:HEAD ?y. ?w nif:nextWord+ ?y. } UNION
	{ ?y nif:nextWord+ ?w. ?x conll:HEAD ?y. ?w nif:nextWord+ ?x. } 
};

# attach non-tokens to root node
DELETE {
	?w conll:HEAD ?s.
} INSERT {
	?w conll:HEAD ?y.
} WHERE {
	?w conll:HEAD ?s.
	?s a nif:Sentence.
	?w conll:POS ?pos
	FILTER(regex(?pos,'^[^A-Z]$|CODE'))
	?y conll:HEAD ?s. [] conll:HEAD ?y.
};

# repair
# if a node has multiple heads, chose the closest one
DELETE {
	?w conll:HEAD ?h1; rdfs:comment ?comment
} WHERE {
	?w conll:HEAD ?h1, ?h2.
	FILTER(?h1!=?h2)
	{ 	?w conll:HEAD ?h1, ?h2. 	# if sentential head is retained along with dependency head, drop the sentential head
		?h1 a nif:Sentence.
		?h2 a nif:Word 
	} UNION {						# keep the closest head to the left
		?w conll:HEAD ?h1, ?h2. 	FILTER(?h1!=?h2)
		?h1 a nif:Word. 
		?h2 a nif:Word.
		?h1 nif:nextWord+ ?h2.
		?h2 nif:nextWord+ ?w.
	} UNION {						# keep the closest head to the right
		?w conll:HEAD ?h1, ?h2. 	FILTER(?h1!=?h2)
		?h1 a nif:Word. 
		?h2 a nif:Word.
		?w nif:nextWord+ ?h2.
		?h2 nif:nextWord+ ?h1.
	} UNION {						# keep the head to the left
		?w conll:HEAD ?h1, ?h2. 	FILTER(?h1!=?h2)
		?h1 a nif:Word. 
		?h2 a nif:Word.
		?h2 nif:nextWord+ ?w.
		?w nif:nextWord+ ?h1.
	}
	bind(concat("remove conll:HEAD "+str(?h1)) AS ?comment)
};

######################
# delete powla:Nodes #
######################
# and their properties
# but only for powla:Nodes that are linked to a nif:Word
# comment for debugging

DELETE {
	?a ?b ?c.
	?d ?e ?a.
} WHERE {
	?a a powla:Node.
	?a terms:HEAD+/a nif:Word.
	?a ?b ?c.
	OPTIONAL { ?d ?e ?a }
};

###############
# POS => UPOS #
###############
# order defines a preference if multiple POSes exist (e.g., in compounds)

# preferred (in compounds)
INSERT { ?w conll:UPOS "NOUN" } WHERE { ?w conll:POS "N". MINUS { ?w conll:UPOS [] }};
INSERT { ?w conll:UPOS "PROPN" } WHERE { ?w conll:POS "NPR". MINUS { ?w conll:UPOS [] }};

# preferred (in ambiguity)
INSERT { ?w conll:UPOS "DET" } WHERE { ?w conll:POS "PRO$". MINUS { ?w conll:UPOS [] }};
INSERT { ?w conll:UPOS "DET" } WHERE { ?w conll:POS "PROS". MINUS { ?w conll:UPOS [] }};

