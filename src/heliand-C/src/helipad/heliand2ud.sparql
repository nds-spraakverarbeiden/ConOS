###########
# pruning #
###########
# remove intermediate representations

DELETE {
	?w conll:EDGE ?e; conll:DEP ?d
} INSERT {
	?w conll:EDGE ?d
} WHERE {
	?w conll:DEP ?d.
	OPTIONAL { ?w conll:EDGE ?e }
};

DELETE {
	?w conll:POS ?shortPos
} WHERE {
	?w conll:POS ?shortPos, ?longPos.
	FILTER(strlen(?shortPos)<strlen(?longPos))
};

DELETE {
	?w conll:POS ?oldPos.
	?w conll:FEAT ?oldF.
} INSERT {
	?w conll:POS ?pfeats
} WHERE {
	{ SELECT ?w (GROUP_CONCAT(distinct ?pos; separator="|") AS ?poses)
	  WHERE {
			?w conll:POS ?pos
		} GROUP BY ?w ORDER BY ?w ?pos
	} 
	OPTIONAL { 
	  SELECT ?w (GROUP_CONCAT(distinct ?f; separator="^") AS ?feats)
	  WHERE {
			?w conll:FEAT ?f
		} GROUP BY ?w ORDER BY ?w ?f
	}
	BIND(IF(bound(?feats), concat(?poses,'^',?feats), ?poses) AS ?pfeats)
	?w conll:POS ?oldPos.
	OPTIONAL { ?w conll:FEAT ?oldF. }
};

###########
# add IDs #
###########

DELETE {
	?a conll:ID ?id
} INSERT {
	?a conll:ID ?new
} WHERE {
	{ SELECT ?a (COUNT(distinct ?pre) AS ?new)
	  WHERE {
		?a a nif:Word.
		?pre nif:nextWord* ?a
	  } GROUP BY ?a
	}
	OPTIONAL { ?a conll:ID ?id }
};